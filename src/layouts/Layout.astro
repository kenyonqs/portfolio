---
import settings from '../data/settings.json';

interface Props {
  title?: string;
  bgImage?: string;
}
const { title = settings.name, bgImage } = Astro.props;

const c = settings.colors || {};
const bg = c.background || '#F2D50C';
const card = c.card || '#2EA33A';
const ink = c.ink || '#101010';

// tiled background: uploaded image, or generated word-sticker SVG
let pattern: string;
if (settings.patternImage) {
  pattern = `url("${settings.patternImage}")`;
} else {
  const word = settings.patternWord || settings.name || 'portfolio';
  const svg = `<svg xmlns='http://www.w3.org/2000/svg' width='340' height='260' viewBox='0 0 340 260'><g transform='rotate(-12 90 70)'><ellipse cx='90' cy='70' rx='85' ry='38' fill='${ink}'/><text x='90' y='82' text-anchor='middle' font-family='Arial Black, sans-serif' font-size='34' font-style='italic' fill='${bg}'>${word}</text></g><g transform='rotate(8 260 195)'><ellipse cx='260' cy='195' rx='85' ry='38' fill='${ink}'/><text x='260' y='207' text-anchor='middle' font-family='Arial Black, sans-serif' font-size='34' font-style='italic' fill='${bg}'>${word}</text></g><circle cx='190' cy='60' r='5' fill='#D42B1E'/><circle cx='40' cy='210' r='5' fill='#D42B1E'/></svg>`;
  pattern = `url("data:image/svg+xml;utf8,${encodeURIComponent(svg)}")`;
}
const bodyStyle = `--bg:${bg};--card:${card};--ink:${ink};--pattern:${pattern};`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,700;1,400&family=Space+Grotesk:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body style={bodyStyle}>
  <div class="bg-layer pattern"></div>
  {bgImage && <div class="bg-layer visible" style={`background-image:url("${bgImage}")`}></div>}
  <div class="bg-layer" id="bgA"></div>
  <div class="bg-layer" id="bgB"></div>

  <slot />

  <script is:inline>
    // hover: crossfade background to the hovered project's image
    const bgA = document.getElementById('bgA'), bgB = document.getElementById('bgB');
    let front = bgA;
    function showBg(url) {
      const next = (front === bgA) ? bgB : bgA;
      next.style.backgroundImage = 'url("' + url + '")';
      next.classList.add('visible');
      front.classList.remove('visible');
      front = next;
    }
    function clearBg() {
      bgA.classList.remove('visible');
      bgB.classList.remove('visible');
    }
    document.querySelectorAll('a.proj[data-bg]').forEach((a) => {
      const im = new Image(); im.src = a.dataset.bg; // preload
      a.addEventListener('mouseenter', () => showBg(a.dataset.bg));
      a.addEventListener('mouseleave', clearBg);
    });
  </script>

  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; }
    body {
      font-family: 'EB Garamond', Georgia, serif;
      color: var(--ink); background: var(--bg); overflow: hidden;
    }
    .sans { font-family: 'Space Grotesk', 'Helvetica Neue', sans-serif; }

    .bg-layer {
      position: fixed; inset: 0; z-index: 0;
      background-size: cover; background-position: center;
      opacity: 0; transition: opacity .45s ease;
      pointer-events: none;
    }
    .bg-layer.pattern { opacity: 1; background: var(--bg); }
    .bg-layer.pattern::after {
      content: ''; position: absolute; inset: 0;
      background-image: var(--pattern);
      background-size: 340px 260px;
    }
    .bg-layer.visible { opacity: 1; }

    .card-wrap {
      position: relative; z-index: 1;
      display: flex; justify-content: center; align-items: center;
      height: 100dvh;
      padding: 48px 16px;
    }
    .card {
      width: min(575px, 100%);
      max-height: 100%;
      overflow-y: auto;
      background: var(--card);
      padding: 0 22px 18px;
      box-shadow: 0 12px 40px rgba(0,0,0,.18);
      scrollbar-width: thin;
      scrollbar-color: rgba(16,16,16,.35) transparent;
    }
    .card::-webkit-scrollbar { width: 6px; }
    .card::-webkit-scrollbar-thumb { background: rgba(16,16,16,.35); border-radius: 3px; }
    .card::-webkit-scrollbar-track { background: transparent; }

    .pills {
      display: flex; gap: 10px;
      position: sticky; top: 0; z-index: 2;
      background: var(--card);
      margin: 0 -22px 26px; padding: 26px 22px 14px;
    }
    .pills a {
      flex: 1; text-align: left;
      font-family: 'Space Grotesk', sans-serif; font-size: 12px; letter-spacing: .02em;
      color: var(--ink); text-decoration: none;
      border: 1px solid rgba(16,16,16,.65); border-radius: 20px;
      padding: 7px 13px;
      transition: background .2s;
      cursor: pointer;
    }
    .pills a:hover { background: rgba(255,255,255,.25); }

    .id-row {
      display: grid; grid-template-columns: 108px 1fr; gap: 16px;
      padding: 14px 0 20px; border-top: 1px solid rgba(16,16,16,.5);
    }
    .id-row h1 { font-size: 15.5px; font-weight: 700; }
    .id-row .sub, .meta { font-style: italic; font-size: 15px; }
    .bio, .desc { font-size: 15px; line-height: 1.32; text-align: left; hyphens: none; text-wrap: pretty; }
    .bio p + p { text-indent: 1.6em; }
    .desc p + p { text-indent: 1.6em; }

    section { border-top: 1px solid rgba(16,16,16,.5); padding: 12px 0 18px; margin-top: 8px; }
    section h2 {
      font-family: 'Space Grotesk', sans-serif; font-weight: 500;
      font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
      margin-bottom: 12px;
    }
    .row { display: grid; grid-template-columns: 108px 1fr; gap: 16px; font-size: 14.5px; line-height: 1.3; margin-bottom: 10px; }
    .row ul { list-style: none; }
    .row li { padding-left: 1.6em; text-indent: -1.6em; margin-bottom: 3px; }

    a.proj {
      color: var(--ink); text-decoration: none;
      border-bottom: 1px dotted rgba(16,16,16,.5);
      cursor: pointer;
    }
    a.proj:hover { background: rgba(255,255,255,.35); border-bottom-style: solid; }

    footer {
      border-top: 1px solid rgba(16,16,16,.5);
      margin-top: 10px; padding-top: 8px;
      font-family: 'Space Grotesk', sans-serif; font-size: 9px; line-height: 1.5; letter-spacing: .02em;
    }

    .gallery figure { margin: 0 0 22px; }
    .gallery img { width: 100%; display: block; }
    .gallery figcaption {
      font-family: 'Space Grotesk', sans-serif; font-size: 11px; letter-spacing: .04em;
      margin-top: 6px; opacity: .85;
    }

    @media (max-width: 560px) {
      .row, .id-row { grid-template-columns: 76px 1fr; gap: 10px; }
      .pills { flex-direction: column; }
      .card-wrap { padding: 0; }
      .card { width: 100%; height: 100dvh; max-height: none; box-shadow: none; }
    }
  </style>
</body>
</html>

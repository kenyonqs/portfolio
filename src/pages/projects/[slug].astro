---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import settings from '../../data/settings.json';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  // same ordering as the CV: year descending, then `order` ascending
  const sorted = [...projects].sort((a, b) => {
    const y = b.data.year.localeCompare(a.data.year, undefined, { numeric: true });
    if (y !== 0) return y;
    return (a.data.order ?? 99) - (b.data.order ?? 99);
  });
  return sorted.map((p, i) => ({
    params: { slug: p.slug },
    props: { project: p, next: sorted[(i + 1) % sorted.length] },
  }));
}

const { project, next } = Astro.props;
const { Content } = await project.render();
const d = project.data;
const gallery = (d.gallery || []).filter((g) => g.image);
const showNext = next.slug !== project.slug;
---
<Layout title={`${d.title} — ${settings.name}`} bgImage={d.backgroundImage || d.mainImage}>
  <div class="card-wrap">
    <div class="card">
      <nav class="pills">
        <a href="/">&#8592; Back to CV</a>
        {settings.email && <a href={`mailto:${settings.email}`}>Email</a>}
        {settings.instagramUrl && <a href={settings.instagramUrl} target="_blank" rel="noopener">Instagram &#8599;</a>}
      </nav>

      <div class="id-row">
        <div>
          <h1>{d.title}</h1>
          <div class="meta">{d.year}{d.venue && ` · ${d.venue}`}</div>
        </div>
        <div class="desc"><Content /></div>
      </div>

      {gallery.length > 0 && (
        <section>
          <h2>Documentation</h2>
          <div class="gallery">
            {gallery.map((g) => (
              <figure>
                <img src={g.image} alt={g.caption || d.title} loading="lazy" />
                {g.caption && <figcaption>{g.caption}</figcaption>}
              </figure>
            ))}
          </div>
        </section>
      )}

      {showNext && (
        <section class="next-nav">
          <a href={`/projects/${next.slug}/`}>Next: {next.data.title} &#8594;</a>
        </section>
      )}
    </div>
  </div>
</Layout>

<style>
  .next-nav a {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    letter-spacing: 0.02em;
    color: var(--ink);
    text-decoration: none;
    border: 1px solid rgba(16, 16, 16, 0.65);
    border-radius: 20px;
    padding: 7px 16px;
  }
 .next-nav {
    text-align: center;
  }
  .next-nav a:hover {
    background: rgba(255, 255, 255, 0.25);
  }
</style>
